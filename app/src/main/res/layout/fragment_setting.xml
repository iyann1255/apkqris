<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setting"
            android:textColor="@color/text"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Server URL" android:textColor="@color/muted" android:paddingTop="8dp" />
        <EditText android:id="@+id/server" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="textUri"
            android:textColor="@color/text" android:textColorHint="@color/muted"
            android:hint="https://qrispay.deviynsp.biz.id" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="License Key" android:textColor="@color/muted" android:paddingTop="12dp" />
        <EditText android:id="@+id/license" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="text"
            android:textColor="@color/text" android:textColorHint="@color/muted"
            android:hint="lc_xxxxxxxx" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Webhook Secret" android:textColor="@color/muted" android:paddingTop="12dp" />
        <EditText android:id="@+id/webhookSecret" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="text"
            android:textColor="@color/text" android:textColorHint="@color/muted"
            android:hint="whsec_xxxxxxxx (untuk verifikasi pembayaran)" />

        <CheckBox android:id="@+id/watchAll" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:paddingTop="12dp"
            android:textColor="@color/text"
            android:text="Pantau semua aplikasi (bukan hanya e-wallet umum)" />

        <Button android:id="@+id/save" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="18dp"
            android:text="Simpan Konfigurasi" />

        <Button android:id="@+id/grant" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="10dp"
            android:text="Aktifkan Akses Notifikasi" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="18dp" android:textSize="12sp" android:textColor="@color/muted"
            android:text="1) Isi Server URL &amp; License Key dari dashboard web.\n2) Simpan.\n3) Tekan 'Aktifkan Akses Notifikasi' lalu izinkan aplikasi ini.\nSelesai — pembayaran masuk otomatis terverifikasi." />
    </LinearLayout>
</ScrollView>
